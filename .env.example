# SuiTrace environment — copy to .env and fill in after deploying.

# From `cd contracts && sui client publish` output (or scripts/deploy.sh):
SUITRACE_PACKAGE_ID=0x...
SUITRACE_REGISTRY_ID=0x...

# Agent signing key (base64 ed25519).
#   sui keytool generate ed25519
#   sui keytool export --key-identity <address> --json   → copy "exportedKey"
AGENT_PRIVATE_KEY=suiprivkey1...
